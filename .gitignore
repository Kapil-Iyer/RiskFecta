# ==========================================================
# RiskFecta .gitignore
# Purpose: keep repo clean, reproducible, and compliant
# ==========================================================


# ----------------------------------------------------------
# Environment variables
# Contains secrets like DATABASE_URL, API keys, etc.
# Never commit these to GitHub
# ----------------------------------------------------------
.env


# ----------------------------------------------------------
# Virtual environments
# Local Python environments should not be committed
# Each developer recreates them from requirements.txt
# ----------------------------------------------------------
venv/
.venv/


# ----------------------------------------------------------
# Raw data (Bloomberg exports)
# These files can be large and may have licensing restrictions
# Keep them locally but never push to GitHub
# ----------------------------------------------------------
data/raw/


# ----------------------------------------------------------
# Processed datasets
# Generated during feature engineering / pipeline runs
# Can be regenerated from raw data
# ----------------------------------------------------------
data/processed/


# ----------------------------------------------------------
# Model artifacts
# Saved ML models from PyTorch / XGBoost training
# These are large and reproducible from training
# ----------------------------------------------------------
*.pt
*.pth
*.pkl
*.joblib


# ----------------------------------------------------------
# CSV data: ignore only raw/processed data dirs, not all CSVs
# Test fixtures (e.g. tests/fixtures/*.csv) and small exports
# may be committed. Do NOT add a global *.csv rule.
# ----------------------------------------------------------
# (data/raw/ and data/processed/ already ignored above)


# ----------------------------------------------------------
# Python cache files
# Automatically generated by Python interpreter
# ----------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd


# ----------------------------------------------------------
# Jupyter Notebook checkpoints
# Temporary autosave files
# ----------------------------------------------------------
.ipynb_checkpoints/


# ----------------------------------------------------------
# OS-specific files
# ----------------------------------------------------------
.DS_Store        # macOS
Thumbs.db        # Windows


# ----------------------------------------------------------
# IDE / editor settings
# These are machine-specific and should not be versioned
# ----------------------------------------------------------
.vscode/
.idea/


# ----------------------------------------------------------
# Logs or temporary runtime files
# ----------------------------------------------------------
*.log
tmp/
temp/